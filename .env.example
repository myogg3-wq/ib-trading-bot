# ===========================================
# IB Trading Bot - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# === IB Gateway ===
IB_HOST=127.0.0.1
IB_PORT=4002          # 4002=Paper, 4001=Live
IB_CLIENT_ID=1
IB_CLIENT_ID_WORKER=92
IB_CLIENT_ID_API=91

# === Broker Routing ===
# ib_only | kis_only | dual_failover
BROKER_MODE=kis_only
PRIMARY_BROKER=kis
SECONDARY_BROKER=ib

# === KIS Open API (optional) ===
# 실전: https://openapi.koreainvestment.com:9443
# 모의: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_QUOTE_EXCHANGE_CODE=NAS
KIS_ORDER_EXCHANGE_CODE=NASD
KIS_QUOTE_PATH=/uapi/overseas-price/v1/quotations/price
KIS_ORDER_PATH=/uapi/overseas-stock/v1/trading/order
KIS_QUOTE_TR_ID=HHDFS00000300
KIS_BUY_TR_ID=TTTT1002U
KIS_SELL_TR_ID=TTTT1006U
KIS_CUSTTYPE=P
# KIS 매수 기준 원화(약 10만원 정책): USD 설정값보다 우선
KIS_TARGET_BUY_KRW=100000
# SELL 신호가 와도 현재 수익률이 기준 미만이면 매도를 보류
SELL_ONLY_IF_PROFIT=true
SELL_MIN_PROFIT_PCT=0.0
# KIS 조회성 GET API 일시 장애 재시도.
KIS_GET_RETRY_COUNT=4
KIS_GET_RETRY_DELAY_SECONDS=0.75
KIS_GET_RETRY_MAX_DELAY_SECONDS=6.0
# 해외 주문은 KIS 제약상 지정가로 내며, 체결 가능성을 높이기 위한 안전 버퍼를 둡니다.
KIS_BUY_LIMIT_MARKUP_PCT=3.0
KIS_SELL_LIMIT_MARKDOWN_PCT=1.0
# 주문 POST 500/끊김은 잔고·미체결 확인 후 중복 위험이 없을 때만 짧게 재시도합니다.
KIS_ORDER_POST_RETRY_COUNT=1
KIS_ORDER_POST_RETRY_DELAY_SECONDS=2.0
# 4시간봉/4시간봉 전략 기준 장외 대기 주문 유효시간. 0이면 만료 비활성.
PENDING_ORDER_TTL_HOURS=96
# 특수 휴장일 수동 캘린더(YYYY-MM-DD,YYYY-MM-DD). 거래소 일정 변경 시 여기만 갱신.
MARKET_HOLIDAYS_US=
MARKET_HOLIDAYS_KRX=
MARKET_HOLIDAYS_HKEX=
MARKET_HOLIDAYS_SSE=
MARKET_HOLIDAYS_SZSE=
MARKET_HOLIDAYS_TSE=

# === Webhook Security ===
WEBHOOK_SECRET=your_strong_secret_key_here
WEBHOOK_PORT=8000
WEBHOOK_ALLOW_ANY_IP=false
TV_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.17.0.1,172.18.0.1
WEBHOOK_ENQUEUE_TIMEOUT_SECONDS=1.0
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=604800
WEBHOOK_SLOW_REQUEST_MS=1000
# false면 "트레이딩뷰 알림 수신/큐 등록" 같은 디버그성 텔레그램 알림을 숨깁니다.
TELEGRAM_VERBOSE_WEBHOOK_ALERTS=false
# Optional: comma-separated TradingView symbol allowlist (empty = allow all)
# Example: IBB,BNDX,HERO,XITK
ALLOWED_TICKERS=
# true면 allowlist 밖이어도 이미 보유 중인 종목의 SELL은 청산을 위해 허용합니다.
ALLOW_SELL_FOR_OPEN_POSITIONS_OUTSIDE_ALLOWLIST=true

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Database ===
# Local run example: ...@localhost:5432/...
# Docker compose example: ...@db:5432/...
DATABASE_URL=postgresql+asyncpg://tradingbot:your_db_password@localhost:5432/tradingbot
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=tradingbot

# === Redis ===
# Local run example: redis://localhost:6379/0
# Docker compose example: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# === Signal Loom Web / Google OAuth ===
# Public base URL used when building Signal Loom callback URLs
# Example local preview: http://127.0.0.1:8766
# Example production: https://signal-loom.example.com
PLATFORM_PUBLIC_BASE_URL=
# Change this to a long random secret before enabling OAuth
PLATFORM_OAUTH_STATE_SECRET=change_me_platform_oauth
# Redirect URI:
# {PLATFORM_PUBLIC_BASE_URL}/api/platform/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# === Trading Defaults ===
DEFAULT_BUY_AMOUNT_USD=300
DEFAULT_MAX_OPEN_POSITIONS=200
DEFAULT_MAX_DAILY_BUYS=80
DEFAULT_MAX_TOTAL_INVESTMENT=90000
DEFAULT_MAX_PER_TICKER=5
DEFAULT_MAX_DAILY_LOSS=5000
DEFAULT_MIN_CASH_RESERVE=1000

# === Order Worker ===
MAX_ORDER_RETRIES=3
